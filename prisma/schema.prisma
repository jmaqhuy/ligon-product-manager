// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================
// Module 1: Users & Auth
// ============================
model User {
  id                   String   @id @default(cuid())
  email                String   @unique
  passwordHash         String   @map("password_hash")
  fullName             String   @map("full_name")
  nameAbbreviation     String   @map("name_abbreviation")
  role                 String   @default("employee") // employee | manager | boss
  status               String   @default("active") // active | inactive
  startDate            DateTime @default(now()) @map("start_date")
  avatarUrl            String?  @map("avatar_url")
  notificationSettings String?  @map("notification_settings") // JSON string
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  // Relations
  ideas                Idea[]           @relation("CreatedBy")
  assignedFiles        Idea[]           @relation("FileAssignee")
  amazonAssignedPhotos AmazonListing[]  @relation("AmazonPhotoAssignee")
  etsyAssignedPhotos   EtsyListing[]    @relation("EtsyPhotoAssignee")
  sellingAccounts      SellingAccount[] @relation("AccountCreatedBy")
  notifications   Notification[]
  auditLogs       AuditLog[]
  ordersDesigned  Order[]          @relation("OrderDesigner")
  ordersProduced  Order[]          @relation("OrderProducer")

  @@map("users")
}

// ============================
// Module 2: Ideas / Products
// ============================
model Idea {
  id                String   @id @default(cuid())
  msku              String   @unique
  autoGenerateMsku  Boolean  @default(true) @map("auto_generate_msku")
  createdById       String   @map("created_by")
  topicId           String   @map("topic_id")
  aiModelId         String   @map("ai_model_id")
  prompt            String
  sourceLinks       String   @default("[]") @map("source_links") // JSON array of strings
  mainImageUrl      String   @map("main_image_url")
  status            String   @default("reviewing") // reviewing | revision_requested | approved | rejected
  fileStatus        String   @default("not_requested") @map("file_status") // not_requested | awaiting_file | pending_approval | revision_requested | approved
  fileAssigneeId    String?  @map("file_assignee_id")
  fileRevisionNote  String?  @map("file_revision_note")
  fileAssignee      User?    @relation("FileAssignee", fields: [fileAssigneeId], references: [id])
  designFileUrl     String?  @map("design_file_url")
  // Amazon/Etsy content - filled at idea creation
  title             String?
  description       String?
  // Product dimensions & material
  widthCm           Float?   @map("width_cm")
  heightCm          Float?   @map("height_cm")
  thicknessMm       Float?   @map("thickness_mm")
  material          String?
  reviewComment     String?  @map("review_comment")
  needsReReview     Boolean  @default(false) @map("needs_rereview")
  // Idea source tracking
  source            String   @default("employee") @map("source") // employee | boss | partner
  partnerId         String?  @map("partner_id")
  partnerLabel      String?  @map("partner_label")
  version           Int      @default(1)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  // Relations
  createdBy          User                @relation("CreatedBy", fields: [createdById], references: [id])
  topic              ProductTopic        @relation(fields: [topicId], references: [id])
  aiModel            AiModel             @relation(fields: [aiModelId], references: [id])
  amazonListing      AmazonListing?
  etsyListing        EtsyListing?
  productionRequests ProductionRequest[]
  shipmentItems      ShipmentItem[]
  partner            Partner?            @relation(fields: [partnerId], references: [id])

  @@map("ideas")
}

// ============================
// Module 3: Amazon Listings
// ============================
model AmazonListing {
  id                  String   @id @default(cuid())
  ideaId              String   @unique @map("idea_id")
  sellingAccountId    String?  @map("selling_account_id")
  sku                 String?
  asin                String?
  fnskuCode           String?  @map("fnsku_code")
  fnskuLabelFileUrl   String?  @map("fnsku_label_file_url")
  itemName            String?  @map("item_name")
  itemHighlights      String?  @map("item_highlights")
  bulletPoints        String?  @map("bullet_points") // JSON array of 5 strings
  description         String?
  tags                String?
  slugs               String? // newline separated
  price               Float?
  useSharedMainImage  Boolean  @default(true) @map("use_shared_main_image")
  galleryImages       String?  @map("gallery_images") // JSON array of strings (max 9)
  videoUrl            String?  @map("video_url")
  contentAPlusUrl     String?  @map("content_a_plus_url")
  listingStatus       String   @default("ready") @map("listing_status") // ready | uploading | uploaded | selling | error | fixed | delisted
  listingStatusReason String?  @map("listing_status_reason") // Reason for error/delisted
  fulfillmentType     String   @default("FBA") @map("fulfillment_type") // FBA | FBM
  campAuto            Boolean  @default(false) @map("camp_auto")
  vineStatus          String   @default("not_enrolled") @map("vine_status") // not_enrolled | enrolled | reviewing | completed

  photosUploaded      Boolean  @default(false) @map("photos_uploaded") // Đã up ảnh thật (không phải ảnh tạm)
  photoStatus         String   @default("not_requested") @map("photo_status") // not_requested | awaiting_photos | pending_approval | revision_requested | approved
  photoAssigneeId     String?  @map("photo_assignee_id")
  photoRevisionNote   String?  @map("photo_revision_note")
  version             Int      @default(1)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  // Relations
  idea           Idea            @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  sellingAccount SellingAccount? @relation(fields: [sellingAccountId], references: [id])
  photoAssignee  User?           @relation("AmazonPhotoAssignee", fields: [photoAssigneeId], references: [id])

  @@map("amazon_listings")
}

// ============================
// Module 4: Etsy Listings
// ============================
model EtsyListing {
  id                  String   @id @default(cuid())
  ideaId              String   @unique @map("idea_id")
  sellingAccountId    String?  @map("selling_account_id")
  title               String?
  listingId           String?  @map("listing_id")
  tags                String? // JSON array of strings (max 13, each max 20 chars)
  description         String?
  price               Float?
  useSharedMainImage  Boolean  @default(true) @map("use_shared_main_image")
  galleryImages       String?  @map("gallery_images") // JSON array of strings (max 9)
  useSharedGallery    Boolean  @default(false) @map("use_shared_gallery") // Use Amazon's gallery
  videoUrl            String?  @map("video_url")
  useAmazonVideo      Boolean  @default(false) @map("use_amazon_video")
  listingStatus       String   @default("ready") @map("listing_status") // ready | uploaded | selling | error | fixed | delisted
  listingStatusReason String?  @map("listing_status_reason") // Reason for error/delisted
  photoStatus         String   @default("not_requested") @map("photo_status") // not_requested | awaiting_photos | pending_approval | revision_requested | approved
  photoAssigneeId     String?  @map("photo_assignee_id")
  photoRevisionNote   String?  @map("photo_revision_note")
  version             Int      @default(1)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  // Relations
  idea           Idea            @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  sellingAccount SellingAccount? @relation(fields: [sellingAccountId], references: [id])
  photoAssignee  User?           @relation("EtsyPhotoAssignee", fields: [photoAssigneeId], references: [id])

  @@map("etsy_listings")
}

// ============================
// Module 5: Selling Accounts
// ============================
model SellingAccount {
  id          String   @id @default(cuid())
  platform    String // amazon | etsy
  name        String
  status      String   @default("active") // active | inactive
  createdById String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  createdBy      User            @relation("AccountCreatedBy", fields: [createdById], references: [id])
  amazonListings AmazonListing[]
  etsyListings   EtsyListing[]
  orders         Order[]
  shipments      Shipment[]

  @@map("selling_accounts")
}

// ============================
// Module 6: Production
// ============================
model ProductionRequest {
  id             String    @id @default(cuid())
  ideaId         String    @map("idea_id")
  type           String    @default("batch") // batch | sample
  priority       String    @default("normal") // urgent | priority | normal
  requestedQty   Int       @map("requested_qty")
  actualQty      Int?      @map("actual_qty")
  requestedAt    DateTime  @default(now()) @map("requested_at")
  completedAt    DateTime? @map("completed_at")
  noteForWorkers String?   @map("note_for_workers")
  shipped        Boolean   @default(false)
  version        Int       @default(1)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  // Relations
  idea  Idea             @relation(fields: [ideaId], references: [id])
  steps ProductionStep[]
  shipmentItems ShipmentItem[]

  @@map("production_requests")
}

model ProductionStep {
  id                  String    @id @default(cuid())
  productionRequestId String    @map("production_request_id")
  stepName            String    @map("step_name") // cutting | printing | etc
  sequenceOrder       Int       @map("sequence_order")
  performedBy         String?   @map("performed_by") // Name string, not FK
  startedAt           DateTime? @map("started_at")
  finishedAt          DateTime? @map("finished_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  // Relations
  productionRequest ProductionRequest @relation(fields: [productionRequestId], references: [id], onDelete: Cascade)

  @@map("production_steps")
}

// ============================
// Module 7: Orders
// ============================
model Order {
  id                     String   @id @default(cuid())
  platform               String // amazon | etsy
  orderId                String   @map("order_id")
  orderDate              DateTime @map("order_date")
  customerName           String   @map("customer_name")
  customerPhone          String?  @map("customer_phone")
  addressLine1           String   @map("address_line1")
  addressLine2           String?  @map("address_line2")
  city                   String
  state                  String?
  zipcode                String?
  country                String
  itemDetail             String?  @map("item_detail")
  weight                 Float?
  length                 Float?
  width                  Float?
  height                 Float?
  service                String?  @default("US Express")
  quantity               Int      @default(1)
  sku                    String // Loose reference to idea.sku/msku
  unitPrice              Float?   @map("unit_price")
  sellingAccountId       String   @map("selling_account_id")
  customNote             String?  @map("custom_note")
  trackingNumber         String?  @map("tracking_number")
  trackingUploaded       Boolean  @default(false) @map("tracking_uploaded")
  productionStatus       String   @default("producing") @map("production_status") // producing | produced | awaiting_fulfillment | fulfilled | ff_amz
  designerId             String?  @map("designer_id")
  orderProductionFileUrl String?  @map("order_production_file_url")
  producerId             String?  @map("producer_id")
  note                   String?
  version                Int      @default(1)
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  // Relations
  sellingAccount SellingAccount @relation(fields: [sellingAccountId], references: [id])
  designer       User?          @relation("OrderDesigner", fields: [designerId], references: [id])
  producer       User?          @relation("OrderProducer", fields: [producerId], references: [id])

  @@map("orders")
}

// ============================
// Module 8: Shipments
// ============================

// Lô hàng gửi đi Amazon FBA
model Shipment {
  id              String    @id @default(cuid())
  status          String    @default("draft") // draft | packing | ready | in_transit | received
  plannedShipDate DateTime  @map("planned_ship_date")
  actualShipDate  DateTime? @map("actual_ship_date")
  shipLine        String?   @map("ship_line") // SEA / SBay / Air VNL — chung cho cả lô
  amazonAccountId String    @map("amazon_account_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  amazonAccount SellingAccount  @relation(fields: [amazonAccountId], references: [id])
  items         ShipmentItem[]
  boxes         ShipmentBox[]

  @@map("shipments")
}

// SKU trong lô hàng — tổng số lượng cần gửi
model ShipmentItem {
  id                  String   @id @default(cuid())
  totalQty            Int      @map("total_qty")
  shipmentId          String   @map("shipment_id")
  ideaId              String   @map("idea_id")
  productionRequestId String?  @map("production_request_id")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  // Relations
  shipment          Shipment           @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  idea              Idea               @relation(fields: [ideaId], references: [id])
  productionRequest ProductionRequest? @relation(fields: [productionRequestId], references: [id])
  boxItems          ShipmentBoxItem[]

  @@map("shipment_items")
}

// Thùng hàng vật lý trong một lô
model ShipmentBox {
  id               String    @id @default(cuid())
  boxName          String    @map("box_name") // Box 1, Box 2, ...
  amazonShipmentId String?   @map("amazon_shipment_id")
  warehouseCode    String?   @map("warehouse_code")
  sourceBoxId      String?   @map("source_box_id") // FK → ShipmentBox — box gốc nếu là bản sao
  lengthCm         Float?    @map("length_cm")
  widthCm          Float?    @map("width_cm")
  heightCm         Float?    @map("height_cm")
  weightKg         Float?    @map("weight_kg")
  labelFileUrl     String?   @map("label_file_url")
  trackingNumber   String?   @map("tracking_number")
  shipmentId       String    @map("shipment_id")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  // Relations
  shipment   Shipment       @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  sourceBox  ShipmentBox?   @relation("BoxCopies", fields: [sourceBoxId], references: [id])
  copies     ShipmentBox[]  @relation("BoxCopies")
  items      ShipmentBoxItem[]

  @@map("shipment_boxes")
}

// Phân bổ SKU vào từng thùng
model ShipmentBoxItem {
  id             String   @id @default(cuid())
  qtyPerBox      Int      @map("qty_per_box") // Số lượng SKU này trong box này
  shipmentBoxId  String   @map("shipment_box_id")
  shipmentItemId String   @map("shipment_item_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  shipmentBox  ShipmentBox  @relation(fields: [shipmentBoxId], references: [id], onDelete: Cascade)
  shipmentItem ShipmentItem @relation(fields: [shipmentItemId], references: [id], onDelete: Cascade)

  @@map("shipment_box_items")
}

// ============================
// Lookup tables
// ============================
model ProductTopic {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  ideas     Idea[]

  @@map("product_topics")
}

model AiModel {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  ideas     Idea[]

  @@map("ai_models")
}

// ============================
// Module 9: Notifications
// ============================
model Notification {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  type        String // idea_approved | revision_requested | photo_assigned | etc
  category    String   @default("general") // photo | production_file | processing_file | general
  message     String
  actionUrl   String?  @map("action_url")
  isRead      Boolean  @default(false) @map("is_read")
  isCompleted Boolean  @default(false) @map("is_completed") // Employee can mark as done
  priority    String   @default("normal") // urgent | priority | normal
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@map("notifications")
}

// ============================
// Audit Logs
// ============================
model AuditLog {
  id          String   @id @default(cuid())
  entityType  String   @map("entity_type") // idea | order | user | etc
  entityId    String   @map("entity_id")
  fieldName   String   @map("field_name")
  oldValue    String?  @map("old_value")
  newValue    String?  @map("new_value")
  changedById String   @map("changed_by")
  changedAt   DateTime @default(now()) @map("changed_at")

  // Relations
  changedBy User @relation(fields: [changedById], references: [id])

  @@map("audit_logs")
}

// ============================
// Worker names (for production dropdown)
// ============================
model Worker {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("workers")
}

// ============================
// Module: Partners
// ============================
model Partner {
  id             String   @id @default(cuid())
  name           String   @unique
  email          String?
  phone          String?
  address        String?
  googleSheetUrl String?  @map("google_sheet_url")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  ideas Idea[]

  @@map("partners")
}

// ============================
// Module 12: System Settings
// ============================
model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique // e.g., "idea_title_max_length"
  value       String // stored as string, parsed to JSON or Number on client
  description String?
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}
